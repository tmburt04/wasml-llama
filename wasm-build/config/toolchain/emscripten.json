{
  "schemaVersion": 2,
  "version": "3.1.69",
  "cacheMode": "frozen",
  "deterministicEnv": {
    "LC_ALL": "C",
    "TZ": "UTC",
    "SOURCE_DATE_EPOCH": "1704067200"
  },
  "compileFlags": [
    "-sALLOW_MEMORY_GROWTH=1",
    "-sMODULARIZE=1",
    "-sEXPORT_ES6=1",
    "-sWASM_BIGINT=1",
    "-sENVIRONMENT=web,worker,node",
    "-sFORCE_FILESYSTEM=1",
    "-msimd128",
    "-mrelaxed-simd",
    "-flto",
    "-DNDEBUG"
  ],
  "threadFlags": [
    "-pthread",
    "-sPTHREAD_POOL_SIZE=Math.min(navigator.hardwareConcurrency||4,16)"
  ],
  "runtimeMethods": [
    "cwrap",
    "ccall",
    "FS",
    "UTF8ToString"
  ],
  "webgpu": {
    "portMode": "builtin",
    "jspi": true,
    "debug": false
  },
  "notes": "Enable thread flags only when the selected artifact explicitly opts in."
}
